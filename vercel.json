{
  "functions": {
    "api/*.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/admin",    "dest": "/public/admin.html" },
    { "src": "/",         "dest": "/public/index.html" },
    { "src": "/(.*)",     "dest": "/public/$1" }
  ]
}
